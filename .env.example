# Variáveis de ambiente para deploy no Railway
# Adicione estas no painel do Railway > Environment Variables

# Porta do servidor (Railway deve definir esta variável como 5000)
PORT=5000

# Nota: No Railway, adicione a variável PORT com valor 5000 nas Environment Variables

# Chave secreta do Flask (gerar com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# URL base da API do FyHub
FYHUB_API_BASE=https://api.fyhub-prod.onz.software

# URL do webhook para alertas de login (opcional - Discord/Slack/Telegram)
MONITOR_WEBHOOK=

# Senha de admin para o painel de monitoramento
ADMIN_PASSWORD=admin123

# Arquivo de log de monitoramento
MONITOR_LOG=/tmp/fyhub_monitor.log
